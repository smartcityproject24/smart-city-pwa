node('master') {
    try {
        def appName = "pwa"
        def addVersion = "test"
        stage('Clean') {
            sh "sudo rm -rf /var/lib/jenkins/workspace/Front_Pwa_test && sudo mkdir -p /var/lib/jenkins/workspace/Front_Pwa_test && sudo chown -R jenkins:jenkins /var/lib/jenkins/workspace/Front_Pwa_test/"
        }
        stage('Checkout') {
            println("Checkout $appName-$addVersion")
            checkout scm
        }
        stage ('Setup service') {
            sh "npm install"
            sh "npm run build"
        }
        stage ('Start service') {
            sh "sudo chown -R skyhunter:skyhunter /var/lib/jenkins/workspace/Front_Pwa_test/"
            sh "sudo systemctl restart smart_pwa_test.service"
        }
    } catch (Exception e) {
        currentBuild.result = "FAILURE"
        println "FAILURE $e"
        //commonNotifyAboutBuildStatus(status: currentBuild.result, exception: e)
        throw e
    } finally {
        println("finally action")
    }
}
